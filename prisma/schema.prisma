generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Admin & Auth ───────────────────────────────────────────────────────────

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  avatar       String?
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens  RefreshToken[]
  passwordResets PasswordResetToken[]
  activities     ActivityLog[]
  orderNotes     OrderNote[]
  returnNotes    ReturnRequest[]      @relation("ReturnAdminNotes")

  @@map("admins")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String   @map("admin_id")
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  adminId   String    @map("admin_id")
  admin     Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([adminId])
  @@map("password_reset_tokens")
}

// ─── Categories ─────────────────────────────────────────────────────────────

enum CategoryStatus {
  ACTIVE
  DRAFT
  INACTIVE
}

model Category {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  description    String?        @db.Text
  image          String?
  banner         String?
  parentId       String?        @map("parent_id")
  parent         Category?      @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]     @relation("CategoryTree")
  sortOrder      Int            @default(0) @map("sort_order")
  status         CategoryStatus @default(ACTIVE)
  isFeatured     Boolean        @default(false) @map("is_featured")
  seoTitle       String?        @map("seo_title")
  seoDescription String?        @map("seo_description") @db.Text
  seoKeywords    String?        @map("seo_keywords")
  ogImage        String?        @map("og_image")
  canonicalUrl   String?        @map("canonical_url")
  schemaJson     Json?          @map("schema_json")
  deletedAt      DateTime?      @map("deleted_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  products Product[]

  @@index([parentId])
  @@index([status])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("categories")
}

// ─── Collections ────────────────────────────────────────────────────────────

enum CollectionStatus {
  ACTIVE
  DRAFT
  INACTIVE
}

model Collection {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  description String?          @db.Text
  image       String?
  sortOrder   Int              @default(0) @map("sort_order")
  status      CollectionStatus @default(ACTIVE)
  deletedAt   DateTime?        @map("deleted_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("collections")
}

// ─── Master colors ──────────────────────────────────────────────────────────

enum ColorStatus {
  ACTIVE
  DRAFT
  INACTIVE
}

model Color {
  id        String      @id @default(cuid())
  name      String      @unique
  hex       String
  sortOrder Int         @default(0) @map("sort_order")
  status    ColorStatus @default(ACTIVE)
  deletedAt DateTime?   @map("deleted_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("colors")
}

// ─── Products ───────────────────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Product {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  skuPrefix        String?       @map("sku_prefix")
  shortDescription String?       @map("short_description") @db.Text
  description      String?       @db.Text
  categoryId       String?       @map("category_id")
  category         Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  collection       String?
  designer         String?
  origin           String?
  brand            String?
  careInstructions String?       @map("care_instructions") @db.Text
  isFeatured       Boolean       @default(false) @map("is_featured")
  isTrending       Boolean       @default(false) @map("is_trending")
  isNewArrival     Boolean       @default(false) @map("is_new_arrival")
  isBestSeller     Boolean       @default(false) @map("is_best_seller")
  status           ProductStatus @default(DRAFT)
  deletedAt        DateTime?     @map("deleted_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  seo           ProductSEO?
  images        ProductImage[]
  variants      ProductVariant[]
  slugHistory   SlugHistory[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
  @@index([slug])
  @@index([isFeatured])
  @@index([isTrending])
  @@map("products")
}

model ProductSEO {
  id                 String  @id @default(cuid())
  productId          String  @unique @map("product_id")
  product            Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  seoTitle           String? @map("seo_title")
  seoDescription     String? @map("seo_description") @db.Text
  seoKeywords        String? @map("seo_keywords")
  canonicalUrl       String? @map("canonical_url")
  metaRobots         String? @map("meta_robots")
  ogTitle            String? @map("og_title")
  ogDescription      String? @map("og_description") @db.Text
  ogImage            String? @map("og_image")
  twitterTitle       String? @map("twitter_title")
  twitterDescription String? @map("twitter_description") @db.Text
  twitterImage       String? @map("twitter_image")
  structuredData     Json?   @map("structured_data")
  sitemapPriority    Float?  @map("sitemap_priority")
  changeFrequency    String? @map("change_frequency")
  redirectUrl        String? @map("redirect_url")
  previewUrl         String? @map("preview_url")

  @@map("product_seo")
}

model SlugHistory {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([slug])
  @@map("slug_history")
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  path       String
  thumbnail  String?
  alt        String?
  sortOrder  Int      @default(0) @map("sort_order")
  isFeatured Boolean  @default(false) @map("is_featured")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([sortOrder])
  @@map("product_images")
}

enum VariantStatus {
  ACTIVE
  INACTIVE
}

model ProductVariant {
  id        String        @id @default(cuid())
  productId String        @map("product_id")
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String        @unique
  barcode   String?
  price     Decimal       @db.Decimal(12, 2)
  salePrice Decimal?      @map("sale_price") @db.Decimal(12, 2)
  costPrice Decimal?      @map("cost_price") @db.Decimal(12, 2)
  stock     Int           @default(0)
  reserved  Int           @default(0)
  weight    Decimal?      @db.Decimal(10, 3)
  length    Decimal?      @db.Decimal(10, 2)
  width     Decimal?      @db.Decimal(10, 2)
  height    Decimal?      @db.Decimal(10, 2)
  status    VariantStatus @default(ACTIVE)
  thumbnail String?
  attributes Json?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@index([productId])
  @@index([sku])
  @@index([stock])
  @@index([status])
  @@map("product_variants")
}

// ─── Customers ──────────────────────────────────────────────────────────────

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model Customer {
  id          String         @id @default(cuid())
  email       String         @unique
  phone       String?
  firstName   String         @map("first_name")
  lastName    String         @map("last_name")
  passwordHash String?       @map("password_hash")
  image       String?
  gender      String?
  dateOfBirth DateTime?      @map("date_of_birth") @db.Date
  status      CustomerStatus @default(ACTIVE)
  totalSpend  Decimal        @default(0) @map("total_spend") @db.Decimal(14, 2)
  lastLoginAt DateTime?      @map("last_login_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  returnRequests ReturnRequest[]
  cart          Cart?

  @@index([status])
  @@index([email])
  @@map("customers")
}

model Address {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label       String?
  fullName    String?  @map("full_name")
  phone       String?
  line1       String
  line2       String?
  landmark    String?
  city        String
  state       String
  postalCode  String   @map("postal_code")
  country     String   @default("IN")
  countryCode String?  @map("country_code")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([customerId])
  @@map("addresses")
}

model Cart {
  id         String     @id @default(cuid())
  customerId String     @unique @map("customer_id")
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String   @map("cart_id")
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  lineKey         String   @map("line_key")
  productId       String   @map("product_id")
  name            String
  brand           String   @default("")
  imageSrc        String   @default("") @map("image_src")
  imageAlt        String   @default("") @map("image_alt")
  sizeId          String   @map("size_id")
  sizeLabel       String   @default("") @map("size_label")
  colorId         String   @default("") @map("color_id")
  colorLabel      String   @default("") @map("color_label")
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 2)
  unitMrp         Decimal  @map("unit_mrp") @db.Decimal(12, 2)
  quantity        Int
  serviceIds      Json     @map("service_ids")
  serviceLabels   Json     @map("service_labels")
  servicesPerUnit Decimal  @default(0) @map("services_per_unit") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([cartId, lineKey])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlist_items")
}

// ─── Orders ─────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  EXCHANGED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  COD
}

enum PaymentMethod {
  CARD
  UPI
  NET_BANKING
  WALLET
  COD
  CASHFREE
  STRIPE
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @map("order_number")
  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  paymentMethod   PaymentMethod? @map("payment_method")
  paymentGateway  String?       @map("payment_gateway")
  cashfreeOrderId String?       @unique @map("cashfree_order_id")
  cashfreePaymentSessionId String? @map("cashfree_payment_session_id")
  paidAt          DateTime?     @map("paid_at")
  subtotal        Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  tax             Decimal       @default(0) @db.Decimal(12, 2)
  shippingCost    Decimal       @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  currency        String        @default("INR")
  shippingAddressId String?       @map("shipping_address_id")
  shippingAddress Address?      @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId  String?       @map("billing_address_id")
  billingAddress  Address?      @relation("BillingAddress", fields: [billingAddressId], references: [id])
  invoiceNumber   String?       @unique @map("invoice_number")
  invoicePath     String?       @map("invoice_path")
  trackingNumber  String?       @map("tracking_number")
  carrier         String?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  orderNotes     OrderNote[]
  reviews        Review[]
  returnRequests ReturnRequest[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String         @map("order_id")
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String         @map("product_id")
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?        @map("variant_id")
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  title     String
  sku       String
  quantity  Int
  price     Decimal        @db.Decimal(12, 2)
  total     Decimal        @db.Decimal(12, 2)
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_status_history")
}

model OrderNote {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  adminId   String?  @map("admin_id")
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  note      String   @db.Text
  isInternal Boolean @default(true) @map("is_internal")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_notes")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  REPORTED
}

model Review {
  id              String       @id @default(cuid())
  productId       String       @map("product_id")
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId      String       @map("customer_id")
  customer        Customer     @relation(fields: [customerId], references: [id])
  orderId         String?      @map("order_id")
  order           Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  rating          Int
  title           String?
  content         String       @db.Text
  status          ReviewStatus @default(PENDING)
  rejectionReason String?      @map("rejection_reason") @db.Text
  isVerifiedPurchase Boolean   @default(false) @map("is_verified_purchase")
  adminReply      String?      @map("admin_reply") @db.Text
  repliedAt       DateTime?    @map("replied_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  images ReviewImage[]

  @@index([productId])
  @@index([customerId])
  @@index([status])
  @@index([rating])
  @@map("reviews")
}

model ReviewImage {
  id        String   @id @default(cuid())
  reviewId  String   @map("review_id")
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  path      String
  thumbnail String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([reviewId])
  @@map("review_images")
}

// ─── Returns & Exchanges ────────────────────────────────────────────────────

enum ReturnType {
  RETURN
  EXCHANGE
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  PICKED_UP
  REFUNDED
  EXCHANGED
  COMPLETED
  CANCELLED
}

enum PickupStatus {
  NOT_SCHEDULED
  SCHEDULED
  PICKED_UP
  FAILED
}

enum RefundStatus {
  NOT_INITIATED
  PENDING
  PROCESSED
  FAILED
}

model ReturnRequest {
  id           String       @id @default(cuid())
  requestNumber String      @unique @map("request_number")
  orderId      String       @map("order_id")
  order        Order        @relation(fields: [orderId], references: [id])
  customerId   String       @map("customer_id")
  customer     Customer     @relation(fields: [customerId], references: [id])
  type         ReturnType
  status       ReturnStatus @default(PENDING)
  reason       String       @db.Text
  amount       Decimal      @db.Decimal(12, 2)
  pickupStatus PickupStatus @default(NOT_SCHEDULED) @map("pickup_status")
  refundStatus RefundStatus @default(NOT_INITIATED) @map("refund_status")
  adminNotes   String?      @map("admin_notes") @db.Text
  adminId      String?      @map("admin_id")
  admin        Admin?       @relation("ReturnAdminNotes", fields: [adminId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  statusHistory ReturnStatusHistory[]
  images        ReturnImage[]

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([type])
  @@map("return_requests")
}

model ReturnStatusHistory {
  id        String       @id @default(cuid())
  returnId  String       @map("return_id")
  return    ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)
  status    ReturnStatus
  note      String?
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([returnId])
  @@map("return_status_history")
}

model ReturnImage {
  id        String        @id @default(cuid())
  returnId  String        @map("return_id")
  return    ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)
  path      String
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([returnId])
  @@map("return_images")
}

// ─── Banners ─────────────────────────────────────────────────────────────────

enum BannerType {
  HOMEPAGE
  CATEGORY
  OFFER
  COLLECTION
  POPUP
  MOBILE
  DESKTOP
}

enum BannerStatus {
  ENABLED
  DISABLED
  SCHEDULED
}

model Banner {
  id          String       @id @default(cuid())
  title       String
  type        BannerType
  image       String
  mobileImage String?      @map("mobile_image")
  linkUrl     String?      @map("link_url")
  buttonText  String?      @map("button_text")
  buttonUrl   String?      @map("button_url")
  sortOrder   Int          @default(0) @map("sort_order")
  status      BannerStatus @default(ENABLED)
  startsAt    DateTime?    @map("starts_at")
  endsAt      DateTime?    @map("ends_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([sortOrder])
  @@map("banners")
}

// ─── Settings ────────────────────────────────────────────────────────────────

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("site_settings")
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?  @map("admin_id")
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
  @@map("activity_logs")
}
