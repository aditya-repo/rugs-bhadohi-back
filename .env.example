NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Pooled URL for the app (Neon: use the "-pooler" host). Required for stable dev connections.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&schema=public&connect_timeout=15

# Direct URL for Prisma migrations (Neon: use the non-pooler host)
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&schema=public&connect_timeout=15

# Local PostgreSQL (alternative)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/rug_casa_admin?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

MAX_FILE_SIZE=10485760

# Cloudinary (required for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=rug-casa

APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

ADMIN_EMAIL=admin@mail.com
ADMIN_PASSWORD=admin:
ADMIN_NAME=Admin

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rugcasa.com

LOG_LEVEL=info
